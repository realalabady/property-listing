rules_version = '2';

// =============================================================================
// PHASE 3 — Hardened Security Rules
// Strict-by-default rules with scoped access by company and permission claims.
// =============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------
    function isSignedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function claims() {
      return request.auth.token;
    }

    function role() {
      return claims().role;
    }

    function companyId() {
      return claims().companyId;
    }

    function isSuperAdmin() {
      return isSignedIn() && role() == 'super_admin';
    }

    function isCompanyMember(cid) {
      return isSignedIn() && companyId() == cid;
    }

    function hasPermission(perm) {
      return isSignedIn()
        && claims().permissions is list
        && perm in claims().permissions;
    }

    function isListingOwnerOrAssignee() {
      return resource.data.createdBy == uid()
             || resource.data.assignedEmployeeId == uid();
    }

    function isLeadCreatePayload(cid) {
      return request.resource.data.companyId == cid
             && request.resource.data.status == 'new'
             && request.resource.data.assignedTo == null
             && request.resource.data.assignedToName == null
             && request.resource.data.firstResponseAt == null
             && request.resource.data.responseTimeMinutes == null
             && request.resource.data.name is string
             && request.resource.data.name.size() > 0
             && request.resource.data.phone is string
             && request.resource.data.phone.size() > 0
             && request.resource.data.source is string
             && request.resource.data.createdAt is timestamp
             && request.resource.data.updatedAt is timestamp;
    }

    // ---------- Companies ----------
    match /companies/{cid} {
      // Public profile readable by anyone (for landing pages)
      allow read: if true;

      // Only super admin or company owner can update the company doc
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin()
                    || (isCompanyMember(cid)
                        && (
                          hasPermission('company_settings_access')
                          || hasPermission('manage_branding')
                        ));
      allow delete: if isSuperAdmin();

      // Settings (branding, theme, integrations)
      match /settings/{docId} {
        allow read: if true;
        allow write: if isSuperAdmin()
                     || (isCompanyMember(cid) && hasPermission('company_settings_access'));
      }

      // Employees — only internal users
      match /employees/{uid} {
        allow read: if isSuperAdmin() || isCompanyMember(cid);
        allow create: if isSuperAdmin()
                      || (isCompanyMember(cid)
                          && hasPermission('create_employee'));
        allow update: if isSuperAdmin()
                      || (isCompanyMember(cid)
                          && hasPermission('edit_employee'));
        allow delete: if isSuperAdmin()
                      || (isCompanyMember(cid) && hasPermission('remove_employee'));
      }

      // Invitations — employee invite workflow
      match /invitations/{invitationId} {
        allow read: if isSuperAdmin()
                    || (isCompanyMember(cid)
                        && (
                          hasPermission('view_employees')
                          || hasPermission('create_employee')
                          || hasPermission('edit_employee')
                          || hasPermission('remove_employee')
                        ));
        allow create: if isSuperAdmin()
                      || (isCompanyMember(cid)
                          && hasPermission('create_employee')
                          && request.resource.data.companyId == cid
                          && request.resource.data.email is string
                          && request.resource.data.role is string
                          && request.resource.data.status == 'pending');
        allow update, delete: if isSuperAdmin()
                              || (isCompanyMember(cid)
                                  && (
                                    hasPermission('create_employee')
                                    || hasPermission('edit_employee')
                                    || hasPermission('remove_employee')
                                  ));
      }

      // Permission groups — reusable grouped permissions for employees
      match /permission_groups/{groupId} {
        allow read: if isSuperAdmin() || isCompanyMember(cid);
        allow create, update: if isSuperAdmin()
                              || (isCompanyMember(cid)
                                  && hasPermission('manage_permission_groups')
                                  && request.resource.data.companyId == cid
                                  && request.resource.data.nameEn is string
                                  && request.resource.data.nameAr is string
                                  && request.resource.data.permissions is list
                                  && request.resource.data.permissions.size() > 0);
        allow delete: if isSuperAdmin()
                      || (isCompanyMember(cid)
                          && hasPermission('manage_permission_groups'));
      }

      // Listings — published listings are public-readable, drafts are internal
      match /listings/{lid} {
        allow read: if resource.data.status == 'published'
                    || isSuperAdmin()
                    || isCompanyMember(cid);
        allow create: if isCompanyMember(cid)
                      && hasPermission('create_listing')
                      && request.resource.data.companyId == cid;
        allow update: if isSuperAdmin()
                      || (isCompanyMember(cid)
                          && request.resource.data.companyId == cid
                          && (
                            hasPermission('edit_listing')
                            || (hasPermission('edit_own_listing') && isListingOwnerOrAssignee())
                          ));
        allow delete: if isSuperAdmin()
                      || (isCompanyMember(cid) && hasPermission('delete_listing'));
      }

      // Leads — public can CREATE (contact form), only internal can read/update
      match /leads/{leadId} {
        allow read: if isSuperAdmin()
                    || (isCompanyMember(cid)
                        && (
                          hasPermission('manage_leads')
                          || (hasPermission('view_own_leads') && resource.data.assignedTo == uid())
                        ));
        allow create: if isLeadCreatePayload(cid);
        allow update: if isSuperAdmin()
                      || (isCompanyMember(cid)
                          && hasPermission('manage_leads')
                          && request.resource.data.companyId == cid
                          && request.resource.data.createdAt == resource.data.createdAt);
        allow delete: if isSuperAdmin()
                      || (isCompanyMember(cid) && hasPermission('manage_leads'));
      }

      // Tasks — internal only
      match /tasks/{tid} {
        allow read: if isSuperAdmin() || isCompanyMember(cid);
        allow create: if isCompanyMember(cid)
                      && hasPermission('assign_tasks')
                      && request.resource.data.companyId == cid;
        allow update: if isSuperAdmin()
                      || (isCompanyMember(cid)
                          && request.resource.data.companyId == cid
                          && (
                            hasPermission('assign_tasks')
                            || (hasPermission('complete_tasks')
                                && resource.data.assignedTo == uid())
                          ));
        allow delete: if isSuperAdmin()
                      || (isCompanyMember(cid) && hasPermission('assign_tasks'));
      }

      // Live KPI overview — written by Cloud Functions only
      match /kpi/{docId} {
        allow read: if isCompanyMember(cid)
                    && (
                      hasPermission('view_kpi')
                      || hasPermission('view_own_kpi')
                    );
        allow write: if false;
      }

      // KPI snapshots — read by company members, write by Cloud Functions only
      match /kpi_snapshots/{snapId} {
        allow read: if isCompanyMember(cid)
                    && (
                      hasPermission('view_kpi')
                      || (hasPermission('view_own_kpi')
                          && resource.data.employeeId == uid())
                    );
        allow write: if false;
      }

      // Activity logs — read by admins, write by Cloud Functions only
      match /activity_logs/{logId} {
        allow read: if isSuperAdmin() || (isCompanyMember(cid) && hasPermission('company_settings_access'));
        allow write: if false;
      }

      // Notifications — recipient reads
      match /notifications/{notifId} {
        allow read: if isCompanyMember(cid);
        allow write: if false;
      }
    }

    // ---------- Platform admins ----------
    match /platform_admins/{uid} {
      allow read: if isSuperAdmin() || request.auth.uid == uid;
      allow write: if false;
    }

    // ---------- Global listings (denormalized public marketplace) ----------
    match /global_listings/{lid} {
      allow read: if true;
      allow write: if false; // only Cloud Functions sync
    }

    // ---------- Broadcast lead requests ----------
    // Customer "property request" inbox shared across all companies. All access
    // is mediated by Admin SDK API routes (/api/lead-requests*), so clients are
    // denied entirely here.
    match /lead_requests/{requestId} {
      allow read, write: if false;
    }

    // ---------- Invitations ----------
    match /invitations/{invId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ---------- Platform-level audit logs ----------
    match /audit_logs/{logId} {
      allow read: if isSuperAdmin();
      allow write: if false;
    }

    // ---------- Subscription plans (public catalog) ----------
    match /plans/{planId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // ---------- Deny by default ----------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
