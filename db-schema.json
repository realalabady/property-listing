        "lastSearchedAt": { "type": "timestamp" },
        "createdAt": { "type": "timestamp" },
        "updatedAt": { "type": "timestamp" }
      }
    },

    "users": {
      "path": "users/{uid}",
      "scope": "top-level",
      "documentId": "Firebase Auth uid",
      "description": "Lightweight global user record written on sign-in (links a uid to its role/company).",
      "fields": {
        "uid": { "type": "string" },
        "role": { "type": "enum(Role)", "nullable": true },
        "companyId": { "type": "ref->companies", "nullable": true },
        "lastSignInAt": { "type": "timestamp" },
        "updatedAt": { "type": "timestamp" }
      }
    },

    "platform_admins": {
      "path": "platform_admins/{uid}",
      "scope": "top-level",
      "documentId": "Firebase Auth uid of a platform-level admin",
      "description": "Allow-list of super-admin users who manage the whole platform (inferred shape).",
      "inferred": true,
      "fields": {
        "uid": { "type": "string", "optional": true },
        "email": { "type": "string", "optional": true },
        "createdAt": { "type": "timestamp", "optional": true }
      }
    },

    "invitations": {
      "path": "invitations/{invId}",
      "scope": "top-level",
      "documentId": "auto-generated / token-based invId",
      "description": "Top-level invitation lookup (mirrors company invitations; used to resolve a token before company context is known).",
      "fields": {
        "id": { "type": "string" },
        "companyId": { "type": "ref->companies" },
        "email": { "type": "string" },
        "role": { "type": "enum(Role)" },
        "token": { "type": "string" },
        "status": { "type": "enum(pending|accepted|expired|revoked)" },
        "expiresAt": { "type": "timestamp" },
        "createdAt": { "type": "timestamp" }
      }
    },

    "audit_logs": {
      "path": "audit_logs/{logId}",
      "scope": "top-level",
      "documentId": "auto-generated logId",
      "description": "Platform-wide audit trail (inferred — no dedicated TS type).",
      "inferred": true,
      "fields": {
        "actorId": { "type": "string", "optional": true },
        "action": { "type": "string", "optional": true },
        "target": { "type": "string", "optional": true },
        "createdAt": { "type": "timestamp", "optional": true }
      }
    },

    "plans": {
      "path": "plans/{planId}",
      "scope": "top-level",
      "documentId": "plan key (e.g. free|starter|pro|enterprise)",
      "description": "Subscription plan catalog/config (inferred shape).",
      "inferred": true,
      "fields": {
        "id": { "type": "string", "optional": true },
        "name": { "type": "string", "optional": true },
        "price": { "type": "number", "optional": true },
        "limits": { "type": "map{...}", "optional": true }
      }
    }
  },

  "relationships": [
    { "from": "companies/{companyId}/* (all subcollections)", "to": "companies/{companyId}", "kind": "parent (ownership / tenant scope)", "via": "subcollection path + companyId field" },
    { "from": "companies.ownerId", "to": "users / companies/{companyId}/employees", "kind": "many-to-one", "via": "uid" },
    { "from": "employees.id", "to": "users.uid", "kind": "one-to-one", "via": "shared Firebase Auth uid" },
    { "from": "employees.permissionGroupIds[]", "to": "companies/{companyId}/permission_groups", "kind": "many-to-many", "via": "groupId" },
    { "from": "listings.assignedEmployeeId", "to": "companies/{companyId}/employees", "kind": "many-to-one", "via": "uid" },
    { "from": "listings.createdBy", "to": "companies/{companyId}/employees", "kind": "many-to-one", "via": "uid" },
    { "from": "leads.listingId", "to": "companies/{companyId}/listings", "kind": "many-to-one", "via": "listingId" },
    { "from": "leads.assignedTo", "to": "companies/{companyId}/employees", "kind": "many-to-one", "via": "uid" },
    { "from": "tasks.assignedTo / createdBy / escalatedTo", "to": "companies/{companyId}/employees", "kind": "many-to-one", "via": "uid" },
    { "from": "tasks.relatedListingId", "to": "companies/{companyId}/listings", "kind": "many-to-one", "via": "listingId" },
    { "from": "tasks.relatedLeadId", "to": "companies/{companyId}/leads", "kind": "many-to-one", "via": "leadId" },
    { "from": "kpi_snapshots.employeeId / kpi.topPerformerId", "to": "companies/{companyId}/employees", "kind": "many-to-one", "via": "uid" },
    { "from": "global_listings.id", "to": "companies/{companyId}/listings", "kind": "one-to-one mirror", "via": "shared document ID (Cloud Function sync, published only)" },
    { "from": "global_listings.companyId / companySlug", "to": "companies", "kind": "many-to-one", "via": "companyId / slug" },
    { "from": "lead_requests.claimedBy[companyId].leadId", "to": "companies/{companyId}/leads", "kind": "one-per-company claim", "via": "leadId" },
    { "from": "customer_searches.customerId", "to": "customers", "kind": "many-to-one", "via": "uid" },
    { "from": "customers.uid", "to": "users.uid", "kind": "one-to-one", "via": "shared Firebase Auth uid" }
  ],

  "denormalization_notes": [
    "Names are frequently copied alongside IDs (assignedToName, assignedEmployeeName, employeeName, companyName, listingTitle) to avoid extra reads. Treat the *Id field as the source of truth and the *Name as a possibly-stale cache.",
    "Counters on companies (listingsCount, activeEmployeesCount) and employees.kpi are denormalized aggregates maintained by Cloud Functions, not transactional truth.",
    "global_listings duplicates a subset of listings for public search; it only contains status='published' documents."
  ]
}
