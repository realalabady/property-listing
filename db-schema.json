      "number": "integer or float",
      "boolean": "true/false",
      "timestamp": "Firestore Timestamp (date-time)",
      "array<T>": "ordered list of T",
      "map{...}": "nested object with the listed sub-fields",
      "enum(...)": "string constrained to the listed values",
      "ref->path": "string holding the ID of a document in the referenced collection"
    }
