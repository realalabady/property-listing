# ---------- Firebase Client (public) ----------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ---------- Firebase Admin (server only — NEVER expose) ----------
# Use base64-encoded service account JSON for easier env handling
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# ---------- App ----------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=RealEstateSaaS

# ---------- Session ----------
SESSION_COOKIE_NAME=__session
SESSION_EXPIRES_IN_DAYS=5

# ---------- Email (optional, required for automatic invitation emails) ----------
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# ---------- Access Policy ----------
# Set to true only if you want users without a company to self-onboard.
ALLOW_PUBLIC_ONBOARDING=false
